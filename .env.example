UDA_APP_NAME=Universal Discovery Server
UDA_JWT_SECRET=change-me-in-production
UDA_JWT_EXP_MIN=120
UDA_DB_URL=sqlite:///./data/discovery.db
UDA_BOOTSTRAP_ADMIN=admin
UDA_DEFAULT_ADMIN_PASSWORD=Admin123£
# Optional: key material used to encrypt locally stored inline secrets.
# If omitted, UDA_JWT_SECRET is used as fallback key derivation source.
UDA_LOCAL_SECRET_ENCRYPTION_KEY=

# Optional local secret values for env-provider references
# Example profile ref: {"$secret":{"provider":"env","key":"SNMP_COMMUNITY"}}
SNMP_COMMUNITY=

# Entra SSO configuration
ENTRA_ENABLED=false
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URI=http://localhost:8080/api/auth/entra/callback
ENTRA_ADMIN_EMAILS=

# Azure Key Vault runtime auth usually uses managed identity in production.
# For local testing, DefaultAzureCredential can use Azure CLI or dev credentials.

# AWS Secrets Manager runtime auth usually uses IAM role/instance profile in production.
# For local testing, configure AWS_PROFILE or AWS_* credentials as needed.
